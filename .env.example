# Variáveis de Ambiente do Marketing Pulse AI
# ATENÇÃO: Nunca suba o arquivo verdadeiro .env ou .env.local para o GitHub. 
# Eles estão protegidos pelo .gitignore. Este é apenas um arquivo de EXEMPLO para sua orientação.

# -----------------
# ⚙️ MODO FRONTEND (React)
# -----------------
# As chaves que começam com REACT_APP_ são vazadas propositalmente para
# a compilação do React. NÃO coloque tokens hiper-seguros aqui.
REACT_APP_API_BASE_URL=http://localhost:8000/api/v1
REACT_APP_ENV=development

# -----------------
# 🔒 MODO BACKEND (Python/FastAPI)
# -----------------
# Todas as chaves do motor da IA ou Banco de Dados devem ficar SECRETA apenas no servidor Backend.
DATABASE_URL=sqlite:///./marketing_pulse.db
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxx
SECRET_KEY=sua_chave_criptografica_muito_segura_aqui
DEBUG=True
